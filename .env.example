# Echo — Environment Variables
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.

# Google Gemini API Key (https://ai.google.dev)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API Key (https://elevenlabs.io)
EXPO_PUBLIC_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice IDs — one per stakeholder archetype
# Get voice IDs from your ElevenLabs dashboard after creating/cloning voices
EXPO_PUBLIC_ELEVENLABS_VOICE_STUDENT=voice_id_for_student
EXPO_PUBLIC_ELEVENLABS_VOICE_WORKER=voice_id_for_worker
EXPO_PUBLIC_ELEVENLABS_VOICE_AUTHORITY=voice_id_for_authority
EXPO_PUBLIC_ELEVENLABS_VOICE_PARENT=voice_id_for_parent
EXPO_PUBLIC_ELEVENLABS_VOICE_DEFAULT=voice_id_for_default

# Sarvam AI API Key (https://sarvam.ai)
# Used for Hindi (hi-IN) and Telugu (te-IN) translation + TTS
EXPO_PUBLIC_SARVAM_API_KEY=your_sarvam_api_key_here

# MongoDB Atlas Data API (https://www.mongodb.com/docs/atlas/api/data-api/)
# Enable the Data API in your Atlas project and get these values
EXPO_PUBLIC_MONGODB_DATA_API_URL=https://data.mongodb-api.com/app/data-xxxxx/endpoint/data/v1
EXPO_PUBLIC_MONGODB_API_KEY=your_atlas_data_api_key_here
EXPO_PUBLIC_MONGODB_DATABASE=echo
EXPO_PUBLIC_MONGODB_COLLECTION=simulations
